#!/bin/bash
# Auto-format staged C# files before commit

# Get staged .cs files only
STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.cs')

if [ -z "$STAGED_CS_FILES" ]; then
  exit 0
fi

# Stash staged .cs files as a backup, then restore them for formatting
git stash push -m "pre-commit backup" -q -- $STAGED_CS_FILES
git stash apply -q

echo "Formatting code with dotnet format..."

dotnet format Rhombus.WinFormsMcp.sln --verbosity quiet --include $STAGED_CS_FILES

if [ $? -ne 0 ]; then
  echo "⚠️  dotnet format failed, restoring original state"
  git checkout stash@{0} -- $STAGED_CS_FILES
  git stash drop -q
  exit 1
fi

# Re-stage any files that were reformatted
git add $STAGED_CS_FILES

# Success — drop the backup stash
git stash drop -q

exit 0
